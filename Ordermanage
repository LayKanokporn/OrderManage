// ============================================================
function weeklyPushSummary() {
  var today   = getTodayTH();
  var dayData = [];
  for (var i=0; i<7; i++) {
    var d      = addDaysTH(today, i);
    var rows   = getOrderRows(function(r) { return formatDateTH(r.deliveryDate) === d && !isRowCancelled(r); });
    var orders = groupRowsByOrder(rows);
    var totalQty = 0;
    rows.forEach(function(r) { totalQty += toNumber(r.qty); });
    if (orders.length > 0) dayData.push("📅 "+d+": "+orders.length+" ออเดอร์ / "+totalQty+" ชิ้น");
  }
  var msg = "📊 สรุปแผนสัปดาห์นี้\n"+today+" เป็นต้นไป\n\n";
  msg += dayData.length === 0 ? "ไม่มีออเดอร์ในสัปดาห์นี้" : dayData.join("\n");
  msg += "\n\nพิมพ์ \"summary 7\" เพื่อดูรายละเอียดค่ะ 🐔";
  ADMIN_USER_IDS.forEach(function(uid) {
    try {
      UrlFetchApp.fetch("https://api.line.me/v2/bot/message/push",{method:"post",headers:{"Authorization":"Bearer "+LINE_CHANNEL_ACCESS_TOKEN,"Content-Type":"application/json"},payload:JSON.stringify({to:uid,messages:[{type:"text",text:msg}]}),muteHttpExceptions:true});
    } catch(e){Logger.log("Push error: "+e);}
  });
}

// ============================================================
//  doPost — PRODUCTION VERSION
// ============================================================
function doPost(e) {
  var replyToken = null;
  try {
    var json = JSON.parse(e.postData.contents);
    if (!json.events || json.events.length === 0)
      return ContentService.createTextOutput("No events");

    for (var ei=0; ei<json.events.length; ei++) {
      var event = json.events[ei];
      replyToken = event.replyToken;

      if (event.type === "postback") {
        handlePostbackEvent(event);
        continue;
      }

      if (event.type !== "message" || event.message.type !== "text") continue;

      var messageId  = event.message.id;
      var source     = event.source || {};
      var sourceType = source.type || "";

      if (isDuplicate(messageId)) continue;

      var text = event.message.text.trim();

      if (sourceType === "group" || sourceType === "room") {
        if (isStopWakeWord(text)) { disableGroupStandby(source); continue; }
        if (isWakeWordOnly(text)) {
          enableGroupStandby(source, GROUP_STANDBY_MINUTES);
          replyLine(replyToken, "🐔 ไก่จ๋ารับฟังอยู่ค่ะ ("+GROUP_STANDBY_MINUTES+" นาที)\nพิมพ์ \"ปิดไก่จ๋า\" เมื่อเสร็จ");
          continue;
        }
        if (startsWithWakeWord(text)) {
          text = stripWakeWord(text);
          enableGroupStandby(source, GROUP_STANDBY_MINUTES);
        } else if (!isGroupStandbyActive(source)) {
          continue;
        }
      }

      var resolvedText  = resolveAlias(text);
      var effectiveText = (resolvedText && resolvedText.toLowerCase() !== text.toLowerCase()) ? resolvedText : text;

      var adminHandled = handleAdminCommand(effectiveText, replyToken);
      if (adminHandled) continue;

      var customerHandled = handleCustomerMessage(event, effectiveText);
      if (customerHandled) continue;

      var isOrderLike = /รายการ\s*:/i.test(text)      ||
                        /รวมทั้งหมด\s*:/i.test(text)   ||
                        /ลูกค้า.*ชื่อคนรับ\s*:/i.test(text) ||
                        /วันที่ส่ง\s*:/i.test(text);

      if (isOrderLike) {
        try {
          var orderData = parseOrder(text);
          var errors    = validateOrder(orderData);
          if (errors.length > 0) {
            replyFlexWithQuickReply(replyToken, buildErrorFlex(errors), QR_NO_ORDERS);
          } else {
            var newOrderId = saveToSheet(orderData, text);
            clearSheetCache();
            replyFlexWithQuickReply(replyToken, buildSuccessFlex(orderData, newOrderId), qrAfterSave(newOrderId));
          }
        } catch (err) {
          replyLine(replyToken, "❌ เกิดข้อผิดพลาด: " + err.message);
        }
        continue;
      }

      var suggestion = buildAutoSuggest(text);
      if (suggestion) {
        replyLineWithQuickReply(replyToken, suggestion, QR_MAIN);
        continue;
      }

      replyFlexWithQuickReply(replyToken, buildNotFoundFlex(), QR_MAIN);
    }

    return ContentService.createTextOutput("OK");

  } catch (error) {
    Logger.log("doPost ERROR: " + error.message + "\n" + error.stack);
    if (replyToken) {
      try { replyLine(replyToken, "❌ ระบบขัดข้อง: " + error.message.substring(0,200)); } catch(e2){}
    }
    return ContentService.createTextOutput("Error: " + error.message);
  }
}

