var UNIT_WORDS = "(ชิ้น|วง|กล่อง|ถุง|อัน|แผ่น|ลูก|ถาด|ห่อ|ปอนด์|ปอนด์ครึ่ง|กก|กิโล|kg|ปอนด์ใหญ่|ปอนด์เล็ก|เซท|set)";
function normalizeItemLines(text) {
  var lines  = String(text||"").split("\n").map(function(s){return s.trim();}).filter(Boolean);
  var merged = [];
  for (var i=0; i<lines.length; i++) {
    var line = lines[i];
    while (i+1 < lines.length &&
      !/^(วันที่ส่ง|payment date|ลูกค้า\(ชื่อคนรับ\)|เบอร์|channel|order type|table\(ชื่อไลน์ลูกค้า\)|ประเภท|เวลาส่ง|สถานที่|ค่าส่ง|รวมทั้งหมด|note|รายการ|google\s*map)\s*:/i.test(lines[i+1]) &&
      (new RegExp("^"+UNIT_WORDS+"\\s*=\\s*[\\d,]+\\s*฿?$","i").test(lines[i+1]) ||
       /^=\s*[\d,]+\s*฿?$/i.test(lines[i+1]) || /^[\d,]+\s*฿?$/i.test(lines[i+1]))
    ) { line += " " + lines[i+1]; i++; }
    merged.push(line);
  }
  return merged;
}
var itemRegexWithUnit = new RegExp("^(?:\\d+\\.|[•\\-])\\s*(.+?)\\s+(\\d+)\\s*(" + UNIT_WORDS.replace(/[()]/g,"") + ")\\s*=\\s*([\\d,]+)\\s*฿?$","i");
var itemRegexSimple   = /^(?:\d+\.|[•\-])\s*(.+?)\s+(\d+)\s*=\s*([\d,]+)\s*฿?$/i;
var itemRegexInformal = /^(?:[•\-\d\.]+)\s*(.+?)\s*\|\s*Qty:\s*(\d+)\s*\|\s*Unit Price:\s*([\d,]+)/i;
var itemRegexNoDash   = /^(.+?)\s+(\d+)\s*(?:ชิ้น|วง|กล่อง|ถุง|อัน|แผ่น|ลูก|ถาด|ห่อ|ปอนด์|กก|กิโล|kg|เซท|set)\s*=\s*([\d,]+)\s*฿?$/i;
function parseItems(text) {
  var lines = normalizeItemLines(text), items = [];
  for (var li=0; li<lines.length; li++) {
    var trimmed = lines[li].trim(); if (!trimmed) continue;
    var m = trimmed.match(itemRegexWithUnit);
    if (m) { var qty=toNumber(m[2]),total=toNumber(m[4]); items.push({menuName:m[1].trim(),unit:m[3].trim(),quantity:qty,unitPrice:qty>0?Math.round(total/qty):0,itemTotal:total}); continue; }
    m = trimmed.match(itemRegexInformal);
    if (m) { var qty2=toNumber(m[2]),up=toNumber(m[3]); items.push({menuName:m[1].trim(),unit:"ชิ้น",quantity:qty2,unitPrice:up,itemTotal:qty2*up}); continue; }
    m = trimmed.match(itemRegexSimple);
    if (m) { var qty3=toNumber(m[2]),total2=toNumber(m[3]); items.push({menuName:m[1].trim(),unit:"ชิ้น",quantity:qty3,unitPrice:qty3>0?Math.round(total2/qty3):0,itemTotal:total2}); continue; }
    m = trimmed.match(itemRegexNoDash);
    if (m) { var qty4=toNumber(m[2]),total3=toNumber(m[3]); items.push({menuName:m[1].trim(),unit:"ชิ้น",quantity:qty4,unitPrice:qty4>0?Math.round(total3/qty4):0,itemTotal:total3}); }
  }
  return items;
}

