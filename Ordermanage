function handlePostbackEvent(event) {
  var data       = event.postback ? event.postback.data : "";
  var replyToken = event.replyToken;
  var userId     = event.source ? event.source.userId : "";
  var params     = parsePostbackData(data);

  switch (params.action) {
    case "order_menu":      startOrderFromMenu(replyToken, userId, params);             return true;
    case "payment":         handlePaymentNotify(replyToken, userId, params.orderId);    return true;
    case "status":          handleCheckStatus(replyToken, userId, params.orderId);      return true;
    case "cancel_request":  handleCustomerCancelRequest(replyToken, userId, params.orderId); return true;
    case "contact":
      replyWithCustomerQuickReply(replyToken,"📞 ติดต่อร้านไก่จ๋า\n\nพิมพ์ข้อความได้เลยค่ะ แอดมินจะตอบกลับเร็วที่สุดนะคะ 🐔\n\n⏰ เวลาทำการ: 09:00 - 20:00",QR_CUSTOMER_MAIN);
      return true;
    default: return false;
  }
}

function parsePostbackData(dataStr) {
  var params = {};
  String(dataStr||"").split("&").forEach(function(pair) {
    var parts = pair.split("=");
    if (parts[0]) params[parts[0]] = decodeURIComponent(parts[1]||"");
  });
  return params;
}

function startOrderFromMenu(replyToken, userId, params) {
  var menuName = params.menuName || "เค้ก";
  var price    = params.price || "0";
  setUserState(userId, {step:"ORDER_QTY", menuName:menuName, price:parseInt(price), items:[]});
  replyWithCustomerQuickReply(replyToken,
    "🍰 "+menuName+" ("+parseInt(price).toLocaleString()+"฿/ชิ้น)\n\nต้องการกี่ชิ้นคะ?",
    [{label:"1 ชิ้น",text:"1"},{label:"2 ชิ้น",text:"2"},{label:"3 ชิ้น",text:"3"},{label:"5 ชิ้น",text:"5"},{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]
  );
}

function handlePaymentNotify(replyToken, userId, orderId) {
  if (orderId) {
    replyWithCustomerQuickReply(replyToken,"📸 แจ้งโอนเงิน Order: "+orderId+"\n\nส่งรูปสลิปมาได้เลยค่ะ\nแอดมินจะตรวจสอบและยืนยันให้นะคะ 🐔",QR_CUSTOMER_MAIN);
  } else {
    replyWithCustomerQuickReply(replyToken,"📸 แจ้งโอนเงิน\n\nกรุณาพิมพ์ Order ID ที่ต้องการแจ้งโอนค่ะ\nตัวอย่าง: ORD-13042569-003427",QR_CUSTOMER_MAIN);
  }
}

function handleCheckStatus(replyToken, userId, orderId) {
  if (orderId) {
    var rows = getOrderRows(function(r){ return r.orderId.toLowerCase()===orderId.toLowerCase(); });
    var mainRows = rows.filter(function(r){ return r.grandTotal!=="" && r.grandTotal!==null && toNumber(r.grandTotal)>0; });
    if (mainRows.length > 0 || rows.length > 0) {
      var main   = mainRows[0] || rows[0];
      var status = getOrderStatus(orderId) || ORDER_STATUS.CONFIRMED;
      replyFlexWithCustomerQR(replyToken, buildOrderStatusFlex(orderId,main.customerName,formatDateTH(main.deliveryDate),status), QR_CUSTOMER_MAIN);
    } else {
      replyWithCustomerQuickReply(replyToken,"❌ ไม่พบ Order: "+orderId+"\nกรุณาตรวจสอบ Order ID อีกครั้งค่ะ",QR_CUSTOMER_MAIN);
    }
  } else {
    var customerOrders = getCustomerLatestOrders(userId, 3);
    if (customerOrders.length > 0) {
      var qrItems = customerOrders.map(function(o){return {label:o.orderId.substring(0,20),postback:"action=status&orderId="+o.orderId};});
      qrItems.push({label:"🏠 เมนูหลัก",text:"เมนู"});
      replyWithCustomerQuickReply(replyToken,"📋 เลือกออเดอร์ที่ต้องการเช็คสถานะค่ะ",qrItems);
    } else {
      replyWithCustomerQuickReply(replyToken,"📋 กรุณาพิมพ์ Order ID ที่ต้องการเช็คค่ะ\nตัวอย่าง: ORD-13042569-003427",QR_CUSTOMER_MAIN);
    }
  }
}

function handleCustomerCancelRequest(replyToken, userId, orderId) {
  var status = getOrderStatus(orderId);
  if (status===ORDER_STATUS.PREPARING || status===ORDER_STATUS.READY) {
    replyWithCustomerQuickReply(replyToken,"⚠️ ขออภัยค่ะ ออเดอร์ "+orderId+" อยู่ในขั้นตอน "+status+" แล้ว\nไม่สามารถยกเลิกได้ค่ะ\n\nกรุณาติดต่อร้านโดยตรงนะคะ 🙏",[{label:"💬 ติดต่อร้าน",postback:"action=contact"}].concat(QR_CUSTOMER_MAIN));
  } else {
    notifyAdminCancelRequest(orderId, userId);
    replyWithCustomerQuickReply(replyToken,"📩 ส่งคำขอยกเลิก "+orderId+" แล้วค่ะ\nแอดมินจะตรวจสอบและแจ้งกลับภายใน 30 นาทีนะคะ 🐔",QR_CUSTOMER_MAIN);
  }
}

