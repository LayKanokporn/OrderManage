function getCakeMenuData() {
  var sheet   = getMenuSheet(), data = sheet.getDataRange().getValues(), headers = data[0];
  return data.slice(1).filter(function(row){return row[0];}).map(function(row){
    return {
      id:          row[headers.indexOf("Menu ID")],
      name:        row[headers.indexOf("Menu Name")],
      price:       toNumber(row[headers.indexOf("Price")]),
      category:    row[headers.indexOf("Category")]||"",
      imageUrl:    row[headers.indexOf("Image URL")]||"",
      badge:       row[headers.indexOf("Badge")]||"",
      description: row[headers.indexOf("Description")]||""
    };
  });
}

// ============================================================
//  ORDER STATUS HELPERS
// ============================================================
function getOrderStatus(orderId) {
  var sheet      = getSheet(), data = sheet.getDataRange().getValues(), headers = data[0];
  var statusCol  = headers.indexOf("Status"), orderIdCol = headers.indexOf("Order ID");
  if (statusCol<0||orderIdCol<0) return ORDER_STATUS.CONFIRMED;
  for (var i=1; i<data.length; i++) {
    if (String(data[i][orderIdCol]).toLowerCase()===String(orderId).toLowerCase())
      return data[i][statusCol] || ORDER_STATUS.CONFIRMED;
  }
  return null;
}
function getOrderStatusFromRow(row) { return row.status || ORDER_STATUS.CONFIRMED; }
function updateOrderStatus(orderId, newStatus) {
  var sheet      = getSheet(), data = sheet.getDataRange().getValues(), headers = data[0];
  var statusCol  = headers.indexOf("Status"), orderIdCol = headers.indexOf("Order ID");
  if (statusCol<0||orderIdCol<0) return false;
  for (var i=1; i<data.length; i++) {
    if (String(data[i][orderIdCol]).toLowerCase()===String(orderId).toLowerCase())
      sheet.getRange(i+1,statusCol+1).setValue(newStatus);
  }
  clearSheetCache(); return true;
}

// ============================================================
//  STATUS UPDATE COMMAND (Admin)
// ============================================================
function handleStatusUpdateCommand(text, replyToken) {
  var match = text.match(/^status\s+(\S+)\s+(\w+)$/i);
  if (!match) return false;
  var orderId   = match[1];
  var statusKey = match[2].toUpperCase();
  var statusMap = {
    "PENDING":    ORDER_STATUS.PENDING,
    "CONFIRMED":  ORDER_STATUS.CONFIRMED,
    "PREPARING":  ORDER_STATUS.PREPARING,
    "READY":      ORDER_STATUS.READY,
    "DELIVERING": ORDER_STATUS.DELIVERING,
    "COMPLETED":  ORDER_STATUS.COMPLETED
  };
  var newStatus = statusMap[statusKey];
  if (!newStatus) {
    replyLine(replyToken,"⚠️ สถานะไม่ถูกต้อง\nใช้: pending / confirmed / preparing / ready / delivering / completed");
    return true;
  }
  updateOrderStatus(orderId, newStatus);
  if (newStatus === ORDER_STATUS.READY) pushReadyNotification(orderId);
  replyFlexWithQuickReply(replyToken, buildAlertFlex("✅ อัปเดตสถานะแล้ว", orderId+" → "+newStatus, "#4CAF50"), QR_MAIN);
  return true;
}

