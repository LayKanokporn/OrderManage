    var d = trimmed.slice("search date ".length).trim().replace(/[\[\]]/g,"");
    replyFlexWithQuickReply(replyToken, buildOrderListFlex(getOrderRows(function(r){return formatDateTH(r.deliveryDate)===d;}), "วันที่ "+d), QR_SEARCH);
