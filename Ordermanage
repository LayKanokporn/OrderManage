    replyLineWithQuickReply(replyToken, msg4, ["clear log confirm","search today","summary"]);
    return true;
  }
  if (lower === "clear log confirm") {
    var props4 = PropertiesService.getScriptProperties(), allProps4 = props4.getProperties();
    var keys4  = Object.keys(allProps4).filter(function(k){return k.startsWith("msg_");});
    keys4.forEach(function(k){props4.deleteProperty(k);});
    replyFlexWithQuickReply(replyToken, buildAlertFlex("🗑️ ลบ log ทั้งหมดแล้ว "+keys4.length+" รายการ","✅ ระบบพร้อมรับออเดอร์ใหม่แล้ว","#4CAF50"), QR_MAIN);
