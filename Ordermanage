// ============================================================
//  SMART SEARCH — 🔧 FIX 2: ปรับให้ search ได้ครบถ้วน
// ============================================================
function smartSearch(keyword) {
  var k = keyword.trim();
  if (/^\d{6,}$/.test(k))
    return {rows:getOrderRows(function(r){return String(r.phone).includes(k);}),label:"เบอร์: "+k,type:"phone"};
  if (/^ord-/i.test(k))
    return {rows:getOrderRows(function(r){return r.orderId.toLowerCase().includes(k.toLowerCase());}),label:"Order ID: "+k,type:"order"};
  // 🔧 FIX: ดึง ALL rows ของลูกค้า (ไม่ filter grandTotal ที่นี่)
  var customerRows = getOrderRows(function(r){return r.customerName.toLowerCase().includes(k.toLowerCase());});
  if (customerRows.length > 0) return {rows:customerRows,label:"ลูกค้า: "+k,type:"customer"};
  var menuRows = getOrderRows(function(r){return r.menuName.toLowerCase().includes(k.toLowerCase());});
  if (menuRows.length > 0) return {rows:menuRows,label:"เมนู: "+k,type:"menu"};
  return {rows:[],label:"ค้นหา: "+k,type:"unknown"};
}

