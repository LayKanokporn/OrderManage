function groupRowsByOrder(rows) {
  var orderMap = {}, orderIds = [];
  rows.forEach(function(r) { var id=String(r.orderId); if(!orderMap[id]){orderMap[id]=[];orderIds.push(id);} orderMap[id].push(r); });
  return orderIds.map(function(id){ return {orderId:id, rows:orderMap[id]}; });
}

