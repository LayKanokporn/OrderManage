      timestamp,
      data.orderId,
      data.deliveryDate,
      data.paymentDate,
      data.customerName,
      String(data.phone||""),
      data.channel,
      data.orderType,
      data.tableName,
      data.deliveryType,
      data.deliveryTime,
      data.location,
      item.menuName,
      item.unit||"",
