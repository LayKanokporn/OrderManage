function pad2(n) {
  return String(n).padStart(2, "0");
}

function isIsoDateTimeString(str) {
  return /^\d{4}-\d{2}-\d{2}T/.test(String(str || "").trim());
}

function parseSlashDateParts(str) {
  var m = String(str || "").trim().match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/);
  if (!m) return null;
  var dd = parseInt(m[1], 10);
  var mm = parseInt(m[2], 10);
  var yy = parseInt(m[3], 10);
  if (yy < 100) yy += 2000;
  if (yy < 2400) yy += 543;
  return { day: dd, month: mm, yearBE: yy };
}

function formatDateFromDateObject(dateObj) {
  if (!(dateObj instanceof Date) || isNaN(dateObj.getTime())) return "";
  var dd = Utilities.formatDate(dateObj, TIMEZONE, "dd");
  var mm = Utilities.formatDate(dateObj, TIMEZONE, "MM");
  var yyyy = parseInt(Utilities.formatDate(dateObj, TIMEZONE, "yyyy"), 10);
  if (yyyy < 2400) yyyy += 543;
  return dd + "/" + mm + "/" + yyyy;
}

/**
 * แปลงค่า (Date object / string dd/MM/CE หรือ dd/MM/BE / ISO string) → "dd/MM/พ.ศ."
 */
function formatDateTH(value) {
  if (value === null || value === undefined || value === "") return "";

  if (value instanceof Date) return formatDateFromDateObject(value);

  var str = String(value).trim();
  if (!str) return "";

  var slash = parseSlashDateParts(str);
  if (slash) return pad2(slash.day) + "/" + pad2(slash.month) + "/" + slash.yearBE;

  if (str.includes("GMT") || str.includes("UTC") || isIsoDateTimeString(str)) {
    var iso = str.match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (iso) {
      var isoYear = parseInt(iso[1], 10);
      if (isoYear >= 2400) {
        return iso[3] + "/" + iso[2] + "/" + isoYear;
      }
    }
    var parsedIso = new Date(str);
    if (!isNaN(parsedIso.getTime())) return formatDateFromDateObject(parsedIso);
    return "";
  }

  var parsed = new Date(str);
  if (!isNaN(parsed.getTime())) return formatDateFromDateObject(parsed);

  return str;
}

/**
 * แปลงค่าเวลา (Date object / string / ISO string) → "H:mm"
 */
function formatTimeTH(value) {
  if (value === null || value === undefined || value === "") return "";

  if (value instanceof Date) {
    if (isNaN(value.getTime())) return "";
    var hm = Utilities.formatDate(value, TIMEZONE, "H:mm");
    return hm === "0:00" ? "" : hm;
  }

  var str = String(value).trim();
  if (!str) return "";

  var timeParts = str.match(/^(\d{1,2}):(\d{2})(?::\d{2})?$/);
  if (timeParts) {
    return parseInt(timeParts[1], 10) + ":" + timeParts[2];
  }

  if (str.includes("GMT") || str.includes("UTC") || isIsoDateTimeString(str)) {
    var parsed = new Date(str);
    if (!isNaN(parsed.getTime())) {
      var hm2 = Utilities.formatDate(parsed, TIMEZONE, "H:mm");
      return hm2 === "0:00" ? "" : hm2;
    }
    return "";
  }

  var parsed2 = new Date(str);
  if (!isNaN(parsed2.getTime())) {
    var hm3 = Utilities.formatDate(parsed2, TIMEZONE, "H:mm");
    return hm3 === "0:00" ? "" : hm3;
  }

  return str;
}

function normalizeMonthInput(value) {
  var cleaned = String(value || "").replace(/[\[\]]/g, "").trim();
  var m = cleaned.match(/^(\d{1,2})\/(\d{2,4})$/);
  if (!m) return cleaned;
  var mm = pad2(m[1]);
  var yyyy = parseInt(m[2], 10);
  if (yyyy < 100) yyyy += 2000;
  if (yyyy < 2400) yyyy += 543;
  return mm + "/" + yyyy;
}

function getTodayTH() {
  var now = new Date();
  return formatDateTH(now);
}

function getTomorrowTH() {
  var now = new Date();
  now.setDate(now.getDate() + 1);
  return formatDateTH(now);
}

function getTimestampTH() {
  var now  = new Date();
  var date = formatDateTH(now);
  var h    = parseInt(Utilities.formatDate(now, TIMEZONE, "H"),  10);
  var mm   = Utilities.formatDate(now, TIMEZONE, "mm");
  var ss   = Utilities.formatDate(now, TIMEZONE, "ss");
  return date + " " + h + ":" + mm + ":" + ss;
}

function thDateToDate(thDateStr) {
  if (!thDateStr) return null;
  var parts = String(thDateStr).trim().split("/");
  if (parts.length !== 3) return null;
  var y = parseInt(parts[2], 10);
  if (y > 2500) y -= 543;
  var m = parseInt(parts[1], 10) - 1;
  var d = parseInt(parts[0], 10);
  var result = new Date(y, m, d);
  if (isNaN(result.getTime())) return null;
  return result;
}

function addDaysTH(thDateStr, days) {
  var d = thDateToDate(thDateStr);
  if (!d) return "";
  d.setDate(d.getDate() + days);
  return formatDateTH(d);
}

function isDeliveryPassed(deliveryDateTH, deliveryTimeRaw) {
  var d = thDateToDate(deliveryDateTH);
  if (!d) return false;

  var now     = new Date();
  var today   = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  var delDay  = new Date(d.getFullYear(),   d.getMonth(),   d.getDate());

  if (delDay < today) return true;
  if (delDay > today) return false;

  var timeStr = formatTimeTH(deliveryTimeRaw);
  if (timeStr) {
    var tp = timeStr.match(/^(\d{1,2}):(\d{2})/);
    if (tp) {
      var dH   = parseInt(tp[1], 10);
      var dMin = parseInt(tp[2], 10);
      var nowH = now.getHours();
      var nowM = now.getMinutes();
      if (dH < nowH || (dH === nowH && dMin <= nowM)) return true;
    }
  }
  return false;
}

function deliveryDateSortKey(thDateStr) {
  var d = thDateToDate(thDateStr);
  return d ? d.getTime() : 0;
}

