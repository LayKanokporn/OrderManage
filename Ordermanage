function getCustomerSheet() {
  var ss    = SpreadsheetApp.openById(SPREADSHEET_ID);
  var sheet = ss.getSheetByName(CUSTOMER_SHEET_NAME);
  if (!sheet) {
    sheet = ss.insertSheet(CUSTOMER_SHEET_NAME);
    sheet.getRange(1,1,1,5).setValues([["User ID","Name","Phone","Last Order Date","Total Orders"]]);
  }
  return sheet;
}

function saveCustomer(userId, name, phone) {
  var sheet = getCustomerSheet(), data = sheet.getDataRange().getValues(), today = getTodayTH();
  for (var i=1; i<data.length; i++) {
    if (data[i][0]===userId) {
      sheet.getRange(i+1,2).setValue(name);
      sheet.getRange(i+1,3).setValue(phone);
      sheet.getRange(i+1,4).setValue(today);
      sheet.getRange(i+1,5).setValue((data[i][4]||0)+1);
      return;
    }
  }
  sheet.appendRow([userId,name,phone,today,1]);
}

function getCustomerIdByName(name) {
  var sheet = getCustomerSheet(), data = sheet.getDataRange().getValues();
  for (var i=1; i<data.length; i++) {
    if (String(data[i][1]).toLowerCase()===String(name).toLowerCase()) return data[i][0];
  }
  return null;
}

function getCustomerLatestOrders(userId, limit) {
  var customerName = getCustomerNameById(userId);
  if (!customerName) return [];
  var rows = getOrderRows(function(r){ return r.customerName.toLowerCase()===customerName.toLowerCase(); });
  var mainRows = rows.filter(function(r){ return r.grandTotal!=="" && r.grandTotal!==null && toNumber(r.grandTotal)>0; });
  return groupRowsByOrder(mainRows.length>0?rows:rows).slice(-limit).reverse();
}

function getCustomerNameById(userId) {
  var sheet = getCustomerSheet(), data = sheet.getDataRange().getValues();
  for (var i=1; i<data.length; i++) { if (data[i][0]===userId) return data[i][1]; }
  return null;
}

