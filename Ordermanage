function handleCustomerMessage(event, processedText) {
  var text       = processedText !== undefined ? processedText : (event.message&&event.message.text?event.message.text.trim():"");
  var replyToken = event.replyToken;
  var userId     = event.source ? event.source.userId : "";
  var lower      = text.toLowerCase();

  if (lower==="ดูเมนูเค้ก"||lower==="เมนูเค้ก"||lower==="เมนู เค้ก"||lower==="menu") {
    var menuFlex = buildCakeMenuCarousel();
    if (menuFlex) replyFlexWithCustomerQR(replyToken, menuFlex, QR_CUSTOMER_MAIN);
    else replyWithCustomerQuickReply(replyToken,"🍰 ยังไม่มีเมนูในระบบค่ะ\nกรุณาติดต่อร้านโดยตรงนะคะ",QR_CUSTOMER_MAIN);
    return true;
  }
  if (lower==="สั่งเค้ก"||lower==="สั่ง"||lower==="order"||lower==="สั่งเลย") {
    startGuidedOrderFlow(replyToken, userId); return true;
  }
  if (lower==="เช็คสถานะ"||lower==="สถานะ"||lower==="check status") {
    handleCheckStatus(replyToken, userId, null); return true;
  }
  if (lower==="แจ้งโอนเงิน"||lower==="แจ้งโอน"||lower==="payment"||lower==="slip") {
    handlePaymentNotify(replyToken, userId, null); return true;
  }
  if (lower==="โปรโมชัน"||lower==="promo"||lower==="โปรโมชั่น") {
    replyFlexWithCustomerQR(replyToken, buildPromoFlex(), QR_CUSTOMER_MAIN); return true;
  }
  if (lower==="ติดต่อร้าน"||lower==="contact"||lower==="ติดต่อ") {
    replyWithCustomerQuickReply(replyToken,"📞 ติดต่อร้านไก่จ๋า\n\nพิมพ์ข้อความได้เลยค่ะ แอดมินจะตอบกลับเร็วที่สุดนะคะ 🐔\n\n⏰ เวลาทำการ: 09:00 - 20:00",QR_CUSTOMER_MAIN); return true;
  }
  if (lower==="ยกเลิกการสั่ง"||lower==="cancel order") {
    clearUserState(userId);
    replyWithCustomerQuickReply(replyToken,"❌ ยกเลิกการสั่งแล้วค่ะ\nจะสั่งใหม่เมื่อไหร่ก็พิมพ์ 'สั่งเค้ก' ได้เลยนะคะ 🐔",QR_CUSTOMER_MAIN); return true;
  }

  var state = getUserState(userId);
  if (state && state.step) return handleGuidedOrderStep(replyToken, userId, text, state);
  return false;
}

function startGuidedOrderFlow(replyToken, userId) {
  setUserState(userId, {step:"CHOOSE_MENU"});
  var menuFlex = buildCakeMenuCarousel();
  if (menuFlex) {
    replyFlexWithCustomerQR(replyToken, menuFlex, [{label:"📋 พิมพ์เอง",text:"📋 คัดลอกฟอร์ม"},{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]);
  } else {
    replyWithCustomerQuickReply(replyToken,"🍰 สั่งเค้กไก่จ๋า\n\nกรอกรายละเอียดออเดอร์ตามฟอร์มด้านล่างได้เลยค่ะ:\n\n"+getOrderFormTemplate(),[{label:"📋 คัดลอกฟอร์ม",text:"📋 คัดลอกฟอร์ม"},{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]);
    clearUserState(userId);
  }
}

function handleGuidedOrderStep(replyToken, userId, text, state) {
  switch (state.step) {
    case "CHOOSE_MENU":
      if (text.includes("คัดลอกฟอร์ม")) { clearUserState(userId); replyLine(replyToken, getOrderFormTemplate()); return true; }
      return false;

    case "ORDER_QTY":
      var qty = parseInt(text);
      if (isNaN(qty)||qty<=0||qty>100) {
        replyWithCustomerQuickReply(replyToken,"⚠️ กรุณาระบุจำนวนเป็นตัวเลข (1-100) ค่ะ",[{label:"1 ชิ้น",text:"1"},{label:"2 ชิ้น",text:"2"},{label:"3 ชิ้น",text:"3"},{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]);
        return true;
      }
      state.items.push({menuName:state.menuName,quantity:qty,unitPrice:state.price,itemTotal:qty*state.price,unit:"ชิ้น"});
      state.step = "ADD_MORE";
      setUserState(userId, state);
      replyWithCustomerQuickReply(replyToken,"✅ "+state.menuName+" x"+qty+" = "+(qty*state.price).toLocaleString()+"฿\n\nต้องการเพิ่มเมนูอื่นไหมคะ?",[{label:"➕ เพิ่มเมนู",text:"เพิ่มเมนู"},{label:"✅ พอแล้ว",text:"พอแล้ว"},{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]);
      return true;

    case "ADD_MORE":
      if (text==="เพิ่มเมนู"||text==="➕ เพิ่มเมนู") { state.step="CHOOSE_MENU"; setUserState(userId,state); startGuidedOrderFlow(replyToken,userId); return true; }
      if (text==="พอแล้ว"||text==="✅ พอแล้ว") {
        state.step="CUSTOMER_NAME"; setUserState(userId,state);
        replyWithCustomerQuickReply(replyToken,"👤 ชื่อคนรับเค้กคะ? (พิมพ์ได้เลย)",[{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]);
        return true;
      }
      return false;

    case "CUSTOMER_NAME":
      state.customerName=text; state.step="PHONE"; setUserState(userId,state);
      replyWithCustomerQuickReply(replyToken,"📞 เบอร์โทรติดต่อคะ?",[{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]);
      return true;

    case "PHONE":
      state.phone=text; state.step="DELIVERY_DATE"; setUserState(userId,state);
      replyWithCustomerQuickReply(replyToken,"📅 วันที่ต้องการรับเค้กคะ?",QR_ORDER_GUIDE);
      return true;

    case "DELIVERY_DATE":
      if (text==="วันนี้")       state.deliveryDate=getTodayTH();
      else if (text==="พรุ่งนี้") state.deliveryDate=getTomorrowTH();
      else if (text==="เลือกวันที่") {
        replyWithCustomerQuickReply(replyToken,"📅 พิมพ์วันที่ในรูปแบบ dd/MM/พ.ศ.\nตัวอย่าง: 15/04/2569",[{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]);
        return true;
      }
      else state.deliveryDate = formatDateTH(text) || text;
      state.step="DELIVERY_TIME"; setUserState(userId,state);
      replyWithCustomerQuickReply(replyToken,"⏰ เวลาที่ต้องการรับเค้กคะ?",[{label:"10:00",text:"10:00"},{label:"12:00",text:"12:00"},{label:"14:00",text:"14:00"},{label:"16:00",text:"16:00"},{label:"18:00",text:"18:00"},{label:"ระบุเอง",text:"ระบุเวลา"}]);
      return true;

    case "DELIVERY_TIME":
      if (text==="ระบุเวลา") {
        replyWithCustomerQuickReply(replyToken,"⏰ พิมพ์เวลาที่ต้องการค่ะ (เช่น 15:30)",[{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]);
        return true;
      }
      state.deliveryTime=text; state.step="DELIVERY_TYPE"; setUserState(userId,state);
      replyWithCustomerQuickReply(replyToken,"🚗 รับเค้กแบบไหนคะ?",QR_DELIVERY_TYPE);
      return true;

    case "DELIVERY_TYPE":
      state.deliveryType=text;
      if (text==="Delivery") {
        state.step="LOCATION"; setUserState(userId,state);
        replyWithCustomerQuickReply(replyToken,"📍 ส่งไปที่ไหนคะ?\nพิมพ์ที่อยู่ หรือส่ง Google Map link ได้เลยค่ะ",[{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]);
      } else {
        state.step="NOTE"; state.location="รับเองที่ร้าน"; setUserState(userId,state);
        replyWithCustomerQuickReply(replyToken,"📝 มีหมายเหตุเพิ่มเติมไหมคะ?\n(เช่น ข้อความบนเค้ก, แพ้อาหาร)",[{label:"ไม่มี",text:"ไม่มี"},{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]);
      }
      return true;

    case "LOCATION":
      state.location=text;
      if (/maps\.app\.goo\.gl|google\.com\/maps|goo\.gl\/maps/.test(text)) { state.googleMap=text; state.location="ดูแผนที่"; }
      state.step="NOTE"; setUserState(userId,state);
      replyWithCustomerQuickReply(replyToken,"📝 มีหมายเหตุเพิ่มเติมไหมคะ?\n(เช่น ข้อความบนเค้ก, แพ้อาหาร)",[{label:"ไม่มี",text:"ไม่มี"},{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]);
      return true;

    case "NOTE":
      state.note=(text==="ไม่มี")?"":text;
      state.step="CONFIRM"; setUserState(userId,state);
      var grandTotal = state.items.reduce(function(sum,item){return sum+item.itemTotal;},0);
      var summary="🧾 สรุปออเดอร์\n\n";
      summary+="👤 "+state.customerName+"\n📞 "+state.phone+"\n📅 "+state.deliveryDate+" ⏰ "+state.deliveryTime+"\n🚗 "+state.deliveryType+"\n";
      if (state.location) summary+="📍 "+state.location+"\n";
      summary+="\n📋 รายการ:\n";
      state.items.forEach(function(item){ summary+="• "+item.menuName+" x"+item.quantity+" = "+item.itemTotal.toLocaleString()+"฿\n"; });
      summary+="\n💰 รวม: "+grandTotal.toLocaleString()+" บาท";
      if (state.note) summary+="\n📝 "+state.note;
      summary+="\n\n✅ ยืนยันสั่งไหมคะ?";
      replyWithCustomerQuickReply(replyToken,summary,[{label:"✅ ยืนยัน",text:"ยืนยันสั่ง"},{label:"✏️ แก้ไข",text:"แก้ไขออเดอร์"},{label:"❌ ยกเลิก",text:"ยกเลิกการสั่ง"}]);
      return true;

    case "CONFIRM":
      if (text==="ยืนยันสั่ง"||text==="✅ ยืนยัน"||text==="ยืนยัน") {
        var orderData = buildOrderDataFromState(state);
        var orderId   = saveToSheet(orderData,"Guided Order via LINE");
        saveCustomer(userId, state.customerName, state.phone);
        clearUserState(userId);
        replyFlexWithCustomerQR(replyToken, buildCustomerOrderConfirmFlex(orderData,orderId), QR_CUSTOMER_MAIN);
        return true;
      }
      if (text==="แก้ไขออเดอร์"||text==="✏️ แก้ไข") { clearUserState(userId); startGuidedOrderFlow(replyToken,userId); return true; }
      return false;

    default:
      clearUserState(userId); return false;
  }
}

function buildOrderDataFromState(state) {
  var grandTotal = state.items.reduce(function(sum,item){return sum+item.itemTotal;},0);
  return {
    orderId:      generateOrderId(),
    deliveryDate: state.deliveryDate,
    paymentDate:  getTodayTH(),
    customerName: state.customerName,
    phone:        state.phone,
    channel:      "LINE",
    orderType:    "Retail",
    tableName:    state.customerName,
    deliveryType: state.deliveryType||"",
    deliveryTime: state.deliveryTime||"",
    location:     state.location||"",
    deliveryFee:  0,
    grandTotal:   grandTotal,
    note:         state.note||"",
    googleMap:    state.googleMap||"",
    paymentStatus:"Pending",
    items:        state.items
  };
}

