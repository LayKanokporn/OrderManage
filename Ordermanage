function getSheetDataCached() {
  var cache  = CacheService.getScriptCache();
  var cached = cache.get("sheet_data");
  if (cached) {
    try { return JSON.parse(cached); } catch(e) {}
  }
  var data = getSheet().getDataRange().getValues();

  // 🔧 FIX 1: แปลง Date objects เป็น string ก่อน cache
  //    เพื่อให้ JSON.stringify/parse ได้ผลตรงกัน
  var safeData = data.map(function(row) {
    return row.map(function(cell) {
      if (cell instanceof Date) {
        // เก็บเป็น ISO string ที่ formatDateTH/formatTimeTH รองรับแล้ว
        return cell.toISOString();
      }
      return cell;
    });
  });

  try { cache.put("sheet_data", JSON.stringify(safeData), 60); } catch(e) {}
  return safeData;
}

function clearSheetCache() {
  CacheService.getScriptCache().remove("sheet_data");
}

