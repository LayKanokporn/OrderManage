// ============================================================
function handleCancel(orderId, confirm, replyToken) {
  var sheet = getSheet(), data = sheet.getDataRange().getValues(), headers = data[0];
  var orderIdCol = headers.indexOf("Order ID"), statusCol = headers.indexOf("Status");
  var matchRows  = [];
  for (var i=1; i<data.length; i++) {
    if (String(data[i][orderIdCol]).trim().toLowerCase() === orderId.trim().toLowerCase()) matchRows.push(i);
  }
  if (matchRows.length === 0) { replyFlexWithQuickReply(replyToken, buildAlertFlex("❌ ไม่พบ Order",orderId,"#F44336"), QR_MAIN); return true; }
  var customerName = data[matchRows[0]][headers.indexOf("Customer Name")] || "-";
  if (!confirm) { replyFlexWithQuickReply(replyToken, buildCancelConfirmFlex(orderId,customerName), ["cancel "+orderId+" confirm","search today"]); return true; }
  if (statusCol < 0) { replyLine(replyToken,"⚠️ ไม่พบคอลัมน์ Status ใน Sheet\nกรุณารัน setupSheet() ก่อนค่ะ"); return true; }
  matchRows.forEach(function(i) { sheet.getRange(i+1, statusCol+1).setValue("Cancelled"); });
  clearSheetCache();
  replyFlexWithQuickReply(replyToken, buildAlertFlex("🗑️ ยกเลิกออเดอร์แล้ว", orderId+" | "+customerName, "#F44336"), QR_MAIN);
  return true;
}

function handleEdit(orderId, replyToken) {
  var rows = getOrderRows(function(r){ return r.orderId.toLowerCase() === orderId.trim().toLowerCase(); });
  if (rows.length === 0) { replyFlexWithQuickReply(replyToken, buildAlertFlex("❌ ไม่พบ Order",orderId,"#F44336"), QR_MAIN); return true; }
  var main            = rows[0];
  var deliveryDateStr = formatDateTH(main.deliveryDate);
  var paymentDateStr  = formatDateTH(main.paymentDate || main.deliveryDate);
  var deliveryTimeStr = formatTimeTH(main.deliveryTime);
  var msg = "✏️ แก้ไข Order: "+orderId+"\n\n";
  msg += "วันที่ส่ง: "+deliveryDateStr+"\nPayment Date: "+paymentDateStr+"\n";
  msg += "ลูกค้า(ชื่อคนรับ): "+main.customerName+"\n";
  if (main.phone) msg += "เบอร์: "+main.phone+"\n";
  msg += "Channel: "+main.channel+"\nOrder Type: "+main.orderType+"\n";
  if (main.deliveryType) msg += "ประเภท: "+main.deliveryType+"\n";
  if (deliveryTimeStr)   msg += "เวลาส่ง: "+deliveryTimeStr+"\n";
  if (main.location)     msg += "สถานที่: "+main.location+"\n";
  if (main.googleMap)    msg += "Google Map: "+main.googleMap+"\n";
  msg += "Table(ชื่อไลน์ลูกค้า): "+(main.tableName||main.customerName)+"\nรายการ:\n";
  rows.forEach(function(r) { msg += "- "+r.menuName+" "+toNumber(r.qty)+" "+(r.unit||"ชิ้น")+"="+toNumber(r.itemTotal)+"\n"; });
  msg += "รวมทั้งหมด: "+toNumber(main.grandTotal)+"\n";
  if (main.note) msg += "Note: "+main.note+"\n";
  msg += "\n💡 คัดลอก → แก้ไข → ส่งกลับมาได้เลยค่ะ\n(ระบบจะบันทึกเป็นออเดอร์ใหม่)";
