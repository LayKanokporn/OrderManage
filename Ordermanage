function buildQuickReplyItems(items) {
  return items.map(function(item) {
    if (typeof item === "string")
      return {type:"action",action:{type:"message",label:item.substring(0,20),text:item}};
    if (item.postback)
      return {type:"action",action:{type:"postback",label:String(item.label).substring(0,20),data:item.postback}};
    return {type:"action",action:{type:"message",label:String(item.label).substring(0,20),text:item.text||item.label}};
