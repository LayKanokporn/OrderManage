    else { var msg3="📋 log วันที่ "+targetDate+" ("+keys2.length+" รายการ)\n\n"; keys2.forEach(function(k){msg3+="  • "+k.replace("msg_","")+"\n";}); replyLineWithQuickReply(replyToken,msg3.trim(),QR_MAIN); }
    return true;
