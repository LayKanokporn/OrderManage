function validateOrder(data) {
  var errors = [];
  if (!data.deliveryDate) errors.push("วันที่ส่ง");
  if (!data.paymentDate)  errors.push("Payment Date");
  if (!data.customerName) errors.push("ลูกค้า");
  if (!data.channel)      errors.push("Channel");
  if (!data.orderType)    errors.push("Order Type");
  if (!data.tableName)    errors.push("Table");
  if (!data.items||data.items.length===0) errors.push("รายการ");
  if (!data.grandTotal)   errors.push("รวมทั้งหมด");
  return errors;
}

