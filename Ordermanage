//  ADMIN COMMANDS ROUTER — 🔧 FIXED search latest
// ============================================================
function handleAdminCommand(text, replyToken) {
  var trimmed = text.trim();
  var lower   = trimmed.toLowerCase();

  if (lower === "help") { replyFlexWithQuickReply(replyToken, buildHelpFlex(), QR_HELP); return true; }
  if (lower === "📋 คัดลอกฟอร์ม") { replyLine(replyToken, getOrderFormTemplate()); return true; }

  if (/^cancel\s+\S+/i.test(lower)) {
    var p = trimmed.split(/\s+/);
    return handleCancel(p[1], p[2] && p[2].toLowerCase() === "confirm", replyToken);
  }
  if (/^ยกเลิก\s+\S+/i.test(trimmed)) {
    var p2 = trimmed.split(/\s+/);
    return handleCancel(p2[1], p2[2] && (p2[2]==="ยืนยัน"||p2[2].toLowerCase()==="confirm"), replyToken);
  }

  if (/^edit\s+\S+/i.test(lower) || /^แก้ไข\s+\S+/i.test(trimmed)) {
    return handleEdit(trimmed.split(/\s+/)[1], replyToken);
  }

  if (/^status\s+\S+\s+\w+/i.test(lower)) {
