function pushPaymentReminders() {
  var pendingOrders = getOrderRows(function(r) {
    var status = getOrderStatusFromRow(r);
    return status===ORDER_STATUS.PENDING && r.grandTotal!=="" && r.grandTotal!==null && toNumber(r.grandTotal)>0;
  });
  var orders = groupRowsByOrder(pendingOrders);
  orders.forEach(function(o) {
    var main       = o.rows[0];
    var customerId = getCustomerIdByName(main.customerName);
    if (!customerId) return;
    pushFlexMessage(customerId, buildPaymentReminderFlex(o.orderId,main.customerName,toNumber(main.grandTotal),12));
  });
  Logger.log("Sent "+orders.length+" payment reminders");
}

function pushPickupReminders() {
  var tomorrowTH = getTomorrowTH();
  var rows = getOrderRows(function(r){ return formatDateTH(r.deliveryDate)===tomorrowTH&&r.grandTotal!==""&&r.grandTotal!==null&&!isRowCancelled(r); });
  var orders = groupRowsByOrder(rows);
  orders.forEach(function(o) {
    var main       = o.rows[0];
    var customerId = getCustomerIdByName(main.customerName);
    if (!customerId) return;
    var timeStr = formatTimeTH(main.deliveryTime);
    var msg = REMINDER_MESSAGES.PICKUP_TOMORROW
      .replace("{orderId}", o.orderId)
      .replace("{time}",    timeStr||"ตามนัดหมาย")
      .replace("{location}",main.location||"ร้านไก่จ๋า");
    pushTextMessage(customerId, msg);
  });
  Logger.log("Sent "+orders.length+" pickup reminders");
}

function pushReadyNotification(orderId) {
  var rows = getOrderRows(function(r){ return r.orderId===orderId; });
  var mainRows = rows.filter(function(r){ return r.grandTotal!=="" && r.grandTotal!==null && toNumber(r.grandTotal)>0; });
  if (mainRows.length === 0 && rows.length === 0) return;
  var customerId = getCustomerIdByName((mainRows[0]||rows[0]).customerName);
  if (!customerId) return;
  pushTextMessage(customerId, REMINDER_MESSAGES.READY.replace("{orderId}",orderId));
}

function pushReviewRequests() {
  var yesterdayTH = addDaysTH(getTodayTH(),-1);
  var rows = getOrderRows(function(r){ return formatDateTH(r.deliveryDate)===yesterdayTH&&r.grandTotal!==""&&r.grandTotal!==null&&getOrderStatusFromRow(r)===ORDER_STATUS.COMPLETED; });
  var orders = groupRowsByOrder(rows);
  orders.forEach(function(o) {
    var customerId = getCustomerIdByName(o.rows[0].customerName);
    if (!customerId) return;
    pushTextMessage(customerId, REMINDER_MESSAGES.REVIEW);
  });
  Logger.log("Sent "+orders.length+" review requests");
}

function pushTextMessage(userId, text) {
  try {
    UrlFetchApp.fetch("https://api.line.me/v2/bot/message/push",{method:"post",headers:{"Authorization":"Bearer "+LINE_CHANNEL_ACCESS_TOKEN,"Content-Type":"application/json"},payload:JSON.stringify({to:userId,messages:[{type:"text",text:String(text).substring(0,5000)}]}),muteHttpExceptions:true});
  } catch(e){Logger.log("Push error: "+e);}
}

function pushFlexMessage(userId, flexPayload) {
  try {
    UrlFetchApp.fetch("https://api.line.me/v2/bot/message/push",{method:"post",headers:{"Authorization":"Bearer "+LINE_CHANNEL_ACCESS_TOKEN,"Content-Type":"application/json"},payload:JSON.stringify({to:userId,messages:[flexPayload]}),muteHttpExceptions:true});
  } catch(e){Logger.log("Push error: "+e);}
}

