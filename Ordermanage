function formatPhoneNumber(value) {
  if (!value && value !== 0) return "";
  var str = String(value).replace(/\.0$/,"").trim();
  if (/^\d{9}$/.test(str)) return "0" + str;
  return str;
}

// ============================================================
//  MAIN PARSER
// ============================================================
function extractItemsBlock(text) {
  var match = String(text||"").match(/รายการ\s*:\s*([\s\S]*?)(?:\n\s*(?:รวมทั้งหมด|รวม|ยอดรวม|total)\s*:|$)/i);
  return match ? match[1].trim() : "";
}

function parseOrder(text) {
  var rawDeliveryDate = getValue(text,"วันที่ส่ง");
  var rawPaymentDate  = getValue(text,"Payment Date");
  var itemsBlock      = extractItemsBlock(text);
  var grandTotalRaw = getValue(text,"รวมทั้งหมด")||getValue(text,"รวม")||getValue(text,"ยอดรวม")||getValue(text,"Total");
  if (!grandTotalRaw) {
    var m = String(text).match(/(?:รวมทั้งหมด|รวม|ยอดรวม|total)\s*:?\s*([\d,]+)/i);
    if (m) grandTotalRaw = m[1];
  }
  var data = {
    orderId:      getValue(text,"ORDER_ID"),
    deliveryDate: formatDateTH(rawDeliveryDate),
    paymentDate:  formatDateTH(rawPaymentDate||rawDeliveryDate),
    customerName: getValue(text,"ลูกค้า(ชื่อคนรับ)")||getValue(text,"ลูกค้า")||getValue(text,"ชื่อ"),
    phone:        getValue(text,"เบอร์")||getValue(text,"เบอร์โทร")||getValue(text,"Tel")||getValue(text,"Phone"),
    channel:      getValue(text,"Channel")||getValue(text,"ช่องทาง"),
    orderType:    getValue(text,"Order Type")||getValue(text,"ประเภทออเดอร์"),
    tableName:    getValue(text,"Table(ชื่อไลน์ลูกค้า)")||getValue(text,"Table")||getValue(text,"ไลน์"),
    deliveryType: getValue(text,"ประเภท")||getValue(text,"Delivery Type"),
    deliveryTime: getValue(text,"เวลาส่ง")||getValue(text,"เวลา"),
    location:     getValue(text,"สถานที่")||getValue(text,"ที่อยู่")||getValue(text,"Address"),
    deliveryFee:  toNumber(getValue(text,"ค่าส่ง")||getValue(text,"Delivery Fee")),
    grandTotal:   toNumber(grandTotalRaw),
    note:         getValue(text,"Note")||getValue(text,"หมายเหตุ"),
    googleMap:    getValue(text,"Google Map")||getValue(text,"Google map")||getValue(text,"แผนที่"),
    paymentStatus:"Paid",
    items:        []
  };
  if (!data.orderId) data.orderId = generateOrderId();
  data.items = parseItems(itemsBlock);
  if (data.items.length === 0) data.items = parseItems(String(text||""));
  return data;
}

function getValue(text, label) {
  var lines      = String(text||"").split("\n");
  var labelRegex = new RegExp("^"+escapeRegex(label)+"\\s*:?\\s*(.*)$","i");
  for (var i=0; i<lines.length; i++) {
    var m = lines[i].match(labelRegex);
    if (m) {
      var value = (m[1]||"").trim(), j = i+1;
      while (j < lines.length) {
        var next = lines[j].trim();
        if (!next){j++;continue;}
        if (/^(วันที่ส่ง|Payment Date|ลูกค้า\(ชื่อคนรับ\)|ลูกค้า|เบอร์|Channel|Order Type|Table\(ชื่อไลน์ลูกค้า\)|Table|ประเภท|เวลาส่ง|สถานที่|ค่าส่ง|รวมทั้งหมด|รวม|ยอดรวม|Note|หมายเหตุ|รายการ|Google\s*Map|แผนที่)\s*:?/i.test(next)) break;
        if (label !== "รายการ"){value += (value?" ":"")+next;}
        j++;
      }
      return value.trim();
    }
  }
  return "";
}
function escapeRegex(str) { return str.replace(/[.*+?^${}()|[\]\\]/g,"\\$&"); }
function toNumber(value) {
  if (value===null||value===undefined) return 0;
  var n = Number(String(value).replace(/,/g,"").replace(/฿/g,"").replace(/บาท/g,"").replace(/\s/g,"").trim());
  return isNaN(n) ? 0 : n;
}

function generateOrderId() {
  var now  = new Date();
  var dd   = Utilities.formatDate(now, TIMEZONE, "dd");
  var mm   = Utilities.formatDate(now, TIMEZONE, "MM");
  var yyyy = parseInt(Utilities.formatDate(now, TIMEZONE, "yyyy"), 10) + 543;
  var time = Utilities.formatDate(now, TIMEZONE, "HHmmss");
  return "ORD-" + dd + mm + yyyy + "-" + time;
}

