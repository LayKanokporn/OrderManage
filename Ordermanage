      ScriptApp.deleteTrigger(t);
  });
  ScriptApp.newTrigger("pushPaymentReminders").timeBased().everyHours(6).create();
  ScriptApp.newTrigger("pushPickupReminders").timeBased().atHour(18).everyDays(1).create();
  ScriptApp.newTrigger("pushReviewRequests").timeBased().atHour(10).everyDays(1).create();
